{
    "builds":[
        {
            "src":"BillingSoftware/wsgi.py",
            "use":"@vercel/python",
            "config":{
                "maxLambdaSize":"600mb",
                "runtime":"python3.13.1"
            }
        }
    ],
    "routes":[
        {
            "src":"/(.*)",
            "dest":"BillingSoftware/wsgi.py"
        }
    ]
}